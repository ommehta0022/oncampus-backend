# Node Environment
NODE_ENV=production
PORT=4000

# Supabase (Database + Storage + Realtime)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_KEY=eyJxxx...
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Upstash Redis (Sessions + Cache + Rate Limiting)
REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379

# JWT Secrets (Generate with: openssl rand -base64 64)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Firebase Admin (Phone OTP + Push Notifications)
FIREBASE_PROJECT_ID=oncampus-prod
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@oncampus-prod.iam.gserviceaccount.com
FIREBASE_SERVER_KEY=AAAAxxx...

# CORS Origins (comma-separated)
CORS_ORIGINS=https://admin.oncampus.com,https://oncampus.com

# Rate Limits
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_PER_HOUR=5
MESSAGE_RATE_LIMIT_PER_MINUTE=30
JOIN_REQUEST_RATE_LIMIT_PER_HOUR=20

# Security
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,application/pdf
MAX_UPLOAD_SIZE_MB=10
SIGNED_URL_EXPIRES_IN=3600

# Sentry (Optional - Error Monitoring)
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Admin API (If running separately)
ADMIN_API_BASE_URL=http://localhost:4001
ADMIN_JWT_SECRET=your-admin-jwt-secret-min-32-chars
ADMIN_REFRESH_SECRET=your-admin-refresh-secret-min-32-chars

# WebSocket
WS_PORT=4000
WS_PATH=/realtime

# Background Jobs
QUEUE_REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379
